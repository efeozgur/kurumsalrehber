generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Department {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  parentId  Int?
  parent    Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentHierarchy")
  contacts  Contact[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Title {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  contacts  Contact[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Contact {
  id            Int       @id @default(autoincrement())
  firstName     String
  lastName      String
  sicilNo       String?
  titleId       Int?
  title         Title?    @relation(fields: [titleId], references: [id])
  phoneInternal String?
  phoneMobile   String?
  email         String?
  avatar        String?
  departmentId  Int?
  department    Department? @relation(fields: [departmentId], references: [id])
  isFav         Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tip {
  id        Int      @id @default(autoincrement())
  text      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Module {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  name        String
  description String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MealPlan {
  id         Int      @id @default(autoincrement())
  weekStart  String
  dayOfWeek  Int
  soup       String
  mainDishes String   // JSON array: '["yemek1","yemek2"]'
  salad      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model FoodItem {
  id        Int      @id @default(autoincrement())
  name      String
  category  String   // 'soup' | 'main' | 'salad'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, category])
}

model SearchLog {
  id          Int      @id @default(autoincrement())
  query       String?
  departmentId Int?
  titleId     Int?
  contactId   Int?
  resultCount Int      @default(0)
  source      String   @default("search")
  createdAt   DateTime @default(now())
}
