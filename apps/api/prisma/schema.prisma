generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Ward {
  id              Int           @id @default(autoincrement())
  firstName       String
  lastName        String
  tcKimlikNo      String
  dosyaNo         String
  isRemoved       Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  bankAccounts    BankAccount[]
  goldAccounts    GoldAccount[]
}

model BankAccount {
  id        Int      @id @default(autoincrement())
  bankName  String
  iban      String
  amount    Float
  currency  String   // TL, EUR, USD
  termType  String   // vadeli, vadesiz
  wardId    Int
  ward      Ward     @relation(fields: [wardId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GoldAccount {
  id        Int      @id @default(autoincrement())
  bankName  String
  goldType  String   // 24 Ayar, Çeyrek, Yarım, Tam, Cumhuriyet, etc.
  gram      Float    // weight in grams
  quantity  Int      @default(1)
  wardId    Int
  ward      Ward     @relation(fields: [wardId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bank {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  parentId  Int?
  parent    Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentHierarchy")
  contacts  Contact[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Title {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  contacts  Contact[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Contact {
  id            Int       @id @default(autoincrement())
  firstName     String
  lastName      String
  sicilNo       String?
  titleId       Int?
  title         Title?    @relation(fields: [titleId], references: [id])
  phoneInternal String?
  phoneMobile   String?
  email         String?
  avatar        String?
  departmentId  Int?
  department    Department? @relation(fields: [departmentId], references: [id])
  isFav         Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model User {
  id                Int                   @id @default(autoincrement())
  username          String                @unique
  password          String
  role              String                @default("ADMIN")
  modulePermissions UserModulePermission[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
}

model UserModulePermission {
  id       Int    @id @default(autoincrement())
  userId   Int
  moduleId Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}

model Tip {
  id        Int      @id @default(autoincrement())
  text      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Module {
  id              Int                   @id @default(autoincrement())
  key             String                @unique
  name            String
  description     String?
  enabled         Boolean               @default(true)
  userPermissions UserModulePermission[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}

model MealPlan {
  id         Int      @id @default(autoincrement())
  weekStart  String
  dayOfWeek  Int
  soup       String
  mainDishes String   // JSON array: '["yemek1","yemek2"]'
  salad      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model FoodItem {
  id        Int      @id @default(autoincrement())
  name      String
  category  String   // 'soup' | 'main' | 'salad'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, category])
}

model SearchLog {
  id          Int      @id @default(autoincrement())
  query       String?
  departmentId Int?
  titleId     Int?
  contactId   Int?
  resultCount Int      @default(0)
  source      String   @default("search")
  createdAt   DateTime @default(now())
}
